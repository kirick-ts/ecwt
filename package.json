{
	"name": "ecwt",
	"version": "0.4.0",
	"description": "Encrypted CBOR Web Token",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"main": "dist/main.mjs",
	"types": "dist/main.d.mts",
	"exports": {
		".": {
			"types": {
				"import": "./dist/main.d.mts",
				"require": "./dist/main.d.cts"
			},
			"import": "./dist/main.mjs",
			"require": "./dist/main.cjs"
		}
	},
	"engines": {
		"node": ">=16"
	},
	"dependencies": {
		"base-x": "5.0.1",
		"cbor-x": "1.5.6",
		"evilcrypt": "0.2.3",
		"valibot": "1.4.1"
	},
	"peerDependencies": {
		"@kirick/snowflake": "^0.3",
		"lru-cache": "^11",
		"redis": "^4.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@kirick/lint": "0.3.0",
		"@types/node": "22.14.1",
		"eslint": "10.2.0",
		"oxlint": "1.58.0",
		"publint": "0.3.18",
		"tsdown": "0.21.10",
		"typescript": "6.0.2",
		"unplugin-unused": "0.5.7",
		"vitest": "4.1.7"
	},
	"scripts": {
		"build": "tsdown src/main.ts --format esm --format cjs --dts --publint --unused",
		"check": "bun run lint && bun run build && bun run test",
		"lint": "biome format && oxlint && eslint . && tsc",
		"redis:up": "docker ps | grep test-redis >/dev/null || docker run --rm -d -p 16379:6379 --name test-redis redis:7-alpine",
		"test": "bun run redis:up && bun test && npm run test:vitest",
		"test:vitest": "vitest run --no-file-parallelism"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kirick-ts/ecwt.git"
	},
	"keywords": [
		"ecwt",
		"jwt",
		"cbor",
		"encrypted",
		"crypto",
		"aes"
	],
	"author": "Daniil Kirichenko (https://twitter.com/kirickme)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/kirick-ts/ecwt/issues"
	},
	"homepage": "https://github.com/kirick-ts/ecwt#readme"
}
